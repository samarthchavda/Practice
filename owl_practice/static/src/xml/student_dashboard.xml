<?xml version="1.0" encoding="UTF-8"?>

<templates xml:space="preserve">

    <t t-name="owl_practice.StudentDashboard">
        <div class="p-4">
            <h2>Student Dashboard</h2>

            <div class="card p-3 mt-3">
                <h3>Total Students</h3>

                <h1>
                    <t t-esc="state.totalStudents"/>
                </h1>

                <button class="btn btn-primary"
                        t-on-click="showStudentDetails">
                    Show Student Details
                </button>

                 <button class="btn btn-success mt-2"
                         t-on-click="openStudentList">
                    Open Student List View
                </button>

            </div>

            <div class="mt-4" t-if="state.showStudents">
                <h3>Student Details</h3>

                <table class="table table-bordered">
                    <thead>
                        <tr>
                            <th>Student Name</th>
                            <th>Roll No</th>
                            <th>Sports</th>
                        </tr>
                    </thead>

                    <tbody>
                        <tr t-foreach="state.students" t-as="student" t-key="student.id">
                            <td>
                                <t t-esc="student.name"/>
                            </td>

                            <td>
                                <t t-esc="student.roll_no"/>
                            </td>

                            <td>
                                <t t-esc="student.sport_ids"/>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </div>
    </t>

</templates>