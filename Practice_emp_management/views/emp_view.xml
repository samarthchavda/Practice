<!--form view create -->
<!--data is name , phone,birth,salary-->
<!--list view create -->
<!--action create -->
<odoo>
    <record id="view_emp_data_form" model="ir.ui.view">
        <field name="name">emp.data.form</field>
        <field name="model">emp.data</field>
        <field name="arch" type="xml">
            <form string="Employee Management">
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="phone_no"/>
                        <field name="birth_date"/>
                        <field name="salary"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>


<!--    create a list view-->
    <record id="list-view" model="ir.ui.view">
        <field name="name">Employee management list view</field>
        <field name="model">emp.data</field>
        <field name="arch" type="xml">
            <list>
                <field name="name"/>
                <field name="phone_no"/>
                <field name="birth_date"/>
                <field name="salary"/>
<            </list>
        </field>
    </record>

<!--    now create action-->
    <record id="main-action" model="ir.actions.act_window">
        <field name="name">Employees</field>
        <field name="res_model">emp.data</field> <!-- this is showing like a table model data show -->
        <field name="view_mode">list,form</field> <!-- which ui formate show -->
    </record>

    <menuitem id="menu_emp_main" name="employee management"/>
    <menuitem id="menu_emp_list" name="Employee" action="main-action" parent="menu_emp_main"/>

</odoo>
