<odoo>

    <record id="action_sales_invoice_report" model="ir.actions.report">
        <field name="binding_type">report</field>
        <field name="name">Sales Invoice</field>
        <field name="model">sales.order</field>
        <field name="report_type">qweb-pdf</field>
        <field name="report_name">mini_sales_order_system.report_sales_invoice_template</field>
        <field name="report_file">mini_sales_order_system.report_sales_invoice_template</field>
        <field name="binding_model_id" ref="model_sales_order"/>
        <field name="print_report_name">'Invoice - %s' % (object.order_number)</field>
    </record>

    <template id="report_sales_invoice_template">
        <t t-call="web.html_container">
            <t t-foreach="docs" t-as="doc"> <!-- for loop -->
                <t t-call="web.external_layout">
                    <div class="page">

                        <h2 style="text-align:center; margin-bottom:25px;">
                            TAX INVOICE
                        </h2>

                        <div style="width:100%; margin-bottom:20px;">
                            <div style="width:48%; display:inline-block; vertical-align:top;">
                                <h4 style="border-bottom:1px solid #000; padding-bottom:5px;">
                                    Bill To
                                </h4>
                                <p>
                                    <strong>Customer:</strong>
                                    <span t-field="doc.customer_name"/>
                                </p>
                            </div>

                            <div style="width:48%; display:inline-block; vertical-align:top; text-align:right;">
                                <h4 style="border-bottom:1px solid #000; padding-bottom:5px;">
                                    Invoice Details
                                </h4>
                                <p>
                                    <strong>Order No:</strong>
                                    <span t-field="doc.order_number"/>
                                </p>
                                <p>
                                    <strong>Invoice Date:</strong>
                                    <span t-field="doc.date"/>
                                </p>
                                <p>
                                    <strong>Status:</strong>
                                    <span t-field="doc.state"/>
                                </p>
                            </div>
                        </div>

                        <table style="width:100%; border-collapse:collapse; margin-top:20px;">
                            <thead>
                                <tr style="background-color:#f2f2f2;">
                                    <th style="border:1px solid #000; padding:7px; text-align:left;">Product</th>
                                    <th style="border:1px solid #000; padding:7px; text-align:center;">Qty</th>
                                    <th style="border:1px solid #000; padding:7px; text-align:right;">Price</th>
                                    <th style="border:1px solid #000; padding:7px; text-align:right;">Subtotal</th>
                                </tr>
                            </thead>

                            <tbody>
                                <tr t-foreach="doc.order_line_ids" t-as="line">
                                    <td style="border:1px solid #000; padding:7px;">
                                        <span t-field="line.product_id"/>
                                    </td>
                                    <td style="border:1px solid #000; padding:7px; text-align:center;">
                                        <span t-field="line.quantity"/>
                                    </td>
                                    <td style="border:1px solid #000; padding:7px; text-align:right;">
                                        <span t-field="line.price"/>
                                    </td>
                                    <td style="border:1px solid #000; padding:7px; text-align:right;">
                                        <span t-field="line.subtotal"/>
                                    </td>
                                </tr>
                            </tbody>
                        </table>

                        <div style="width:40%; margin-left:auto; margin-top:25px;">
                            <table style="width:100%; border-collapse:collapse;">
                                <tr>
                                    <td style="border:1px solid #000; padding:7px;">
                                        <strong>Subtotal</strong>
                                    </td>
                                    <td style="border:1px solid #000; padding:7px; text-align:right;">
                                        <span t-field="doc.total_amount"/>
                                    </td>
                                </tr>

                                <tr>
                                    <td style="border:1px solid #000; padding:7px;">
                                        <strong>GST 18%</strong>
                                    </td>
                                    <td style="border:1px solid #000; padding:7px; text-align:right;">
                                        <span t-field="doc.gst_amount"/>
                                    </td>
                                </tr>

                                <tr>
                                    <td style="border:1px solid #000; padding:7px;">
                                        <strong>Grand Total</strong>
                                    </td>
                                    <td style="border:1px solid #000; padding:7px; text-align:right;">
                                        <strong>
                                            <span t-field="doc.grand_total"/>
                                        </strong>
                                    </td>
                                </tr>
                            </table>
                        </div>

                        <div style="margin-top:45px; text-align:center; font-size:12px;">
                            <p>Thank you for your business.</p>
                            <p>This is a system generated invoice.</p>
                        </div>

                    </div>
                </t>
            </t>
        </t>
    </template>

</odoo>