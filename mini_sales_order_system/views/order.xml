<odoo>
    <record id="order_list_view" model="ir.ui.view">
        <field name="name">sales.order.list</field>
        <field name="model">sales.order</field>
        <field name="arch" type="xml">
            <list>
                <field name="order_number"/>
                <field name="customer_id"/>
<!--                <field name="quotation_id"/>-->
                <field name="date"/>
                <field name="total_amount"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="order_form_view" model="ir.ui.view">
        <field name="name">sales.order.form</field>
        <field name="model">sales.order</field>
        <field name="arch" type="xml">
            <form>
                <header>

                    <button name="action_export_order_xlsx"
                            string="Export XLSX"
                            type="object"
                            class="btn-primary"
                            />
                   <button name="%(action_sales_invoice_report)d"
                            string="Print Invoice"
                            type="action"
                            class="btn-primary"
                            />
                    <button name="action_order_confirm"
                            string="order confirm"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"
                            id="quotation_send_primary"
                            context="{'validate_analytic': True, 'check_document_layout': True}"
                            data-hotkey="g"
                            />
                    <button name="action_order_cancel"
                            string="cancel"
                            type="object"
                            class="btn-danger"
                            invisible="state != 'confirmed' or has_paid_payment"
                            />
                    <button name="action_order_reset"
                            string="reset to draft"
                            type="object"
                            invisible="state == 'draft' or has_paid_payment"
                            />
                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,cancel"/>
                </header>

                <sheet>
<!--                    smart button like deleviry -->
                    <div class="oe_button_box" name="button_box">

                        <button name="action_order_delivery"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-truck">
                            <field name="delivery_count" widget="statinfo" string="delivery"/>
                        </button>

                        <button name="action_order_invoice"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-file-text-o">
                            <field name="order_invoice" widget="statinfo" string="invoice"/>
                        </button>

                        <button name="action_order_payment"
                                type="object"
                                class="oe_stat_button"
                                icon="fa-money">
                            <field name="order_payment" widget="statinfo" string="payment"/>
                            
                        </button>
                    </div>

                    <group>
                        <field name="order_number"/>
                        <field name="customer_id"/>
<!--                        <field name="quotation_id"/>-->
                        <field name="date"/>
                        <field name="total_amount" readonly="1"/>
                        <field name="has_paid_payment" invisible="1"/>
                        <field name="gst_amount" readonly="1"/>
                        <field name="grand_total" readonly="1"/>
                    </group>

                    <notebook>
                        <page string="Order Lines">
                            <field name="order_line_ids">
                                <list editable="bottom">
                                    <field name="product_id"/>
                                    <field name="quantity"/>
                                    <field name="price"/>
                                    <field name="subtotal" readonly="1"/>
                                </list>
                            </field>
                        </page>
                    </notebook>
                </sheet>
            </form>
        </field>
    </record>

    <record id="sales_delivery_kanban_view" model="ir.ui.view">
        <field name="name">sales.order.kanban</field>
        <field name="model">sales.order</field>
        <field name="arch" type="xml">
            <kanban default_group_by="state">
                <field name="order_number"/>
                <field name="date"/>
                <field name="total_amount"/>
                <field name="state"/>

                <templates>
                     <t t-name="card">
                        <div class="oe_kanban_card p-3">
                            <strong>
                                <field name="order_number"/>
                            </strong>

                            <div>
                                Date:
                                <field name="date"/>
                            </div>

                            <div>
                                Amount:
                                ₹ <field name="total_amount"/>
                            </div>

                            <div>
                                Status:
                                <field name="state"/>
                            </div>
                        </div>
                    </t>
                </templates>
            </kanban>
        </field>
    </record>

    <record id="view_sales_order_search" model="ir.ui.view">
        <field name="name">sales.order.search</field>
        <field name="model">sales.order</field>
        <field name="arch" type="xml">
            <search string="Orders">
                <field name="order_number"/>
                <field name="customer_id"/>
                <filter name="filter_draft"
                        string="Draft"
                        domain="[('state', '=', 'draft')]"/>

                <filter name="filter_confirmed"
                        string="Confirmed"
                        domain="[('state', '=', 'confirmed')]"/>

                <filter name="filter_cancel"
                        string="Cancelled"
                        domain="[('state', '=', 'cancel')]"/>

                <filter name="group_state"
                        string="Group By State"
                        context="{'group_by': 'state'}"/>

                <filter name="group_date"
                        string="Group By Date"
                        context="{'group_by': 'date'}"/>
            </search>
        </field>
    </record>
    <record id="action_order" model="ir.actions.act_window">
        <field name="name">Orders</field>
        <field name="res_model">sales.order</field>
        <field name="view_mode">list,kanban,form</field>
        <field name="search_view_id" ref="view_sales_order_search"/>
    </record>

    <menuitem id="menu_sales_root" name="Sales"/>   <!-- main menu -->

    <!-- sub menu -->
    <menuitem id="menu_order_root"
              name="Orders"
              parent="menu_sales_root"
              sequence="2"/>

    <menuitem id="menu_sales_orders"
              name="Sales Orders"
              parent="menu_order_root"
              action="action_order"
              sequence="1"/>


</odoo>