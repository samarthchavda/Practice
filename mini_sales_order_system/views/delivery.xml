<odoo>
    <record id="sales_delivery_list_view" model="ir.ui.view">
        <field name="name">sales.delivery.list</field>
        <field name="model">sales.delivery</field>
        <field name="arch" type="xml">
            <list>
                <field name="delivery_name"/>
                <field name="order_id"/>
                <field name="delivery_date"/>
                <field name="status"/>
            </list>
        </field>
    </record>
    <record id="action_delivery" model="ir.actions.act_window">
        <field name="name">Delivery</field>
        <field name="res_model">sales.delivery</field>
        <field name="view_mode">list</field>
    </record>

    <menuitem id="menu_sales_delivery"
          name="Delivery"
          parent="menu_sales_root"
          action="action_delivery"
          />

</odoo>