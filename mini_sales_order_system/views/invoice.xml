<odoo>

    <!-- List View -->
    <record id="sales_invoice_list_view" model="ir.ui.view">
        <field name="name">sales.invoice.list</field>
        <field name="model">sales.invoice</field>
        <field name="arch" type="xml">
            <list create="false" edit="false" delete="false">
                <field name="invoice_number"/>
                <field name="order_id"/>
                <field name="invoice_date"/>
                <field name="amount"/>
                <field name="status"/>
            </list>
        </field>
    </record>

    <record id="sales_invoice_form_view" model="ir.ui.view">
        <field name="name">sales.invoice.form</field>
        <field name="model">sales.invoice</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="invoice_number"/>
                        <field name="order_id"/>
                        <field name="invoice_date"/>
                        <field name="amount"/>
                        <field name="status"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <!-- Action -->
    <record id="sales_invoice_action" model="ir.actions.act_window">
        <field name="name">Invoices</field>
        <field name="res_model">sales.invoice</field>
        <field name="view_mode">list,form</field>
    </record>

</odoo>