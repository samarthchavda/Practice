<odoo>
    <data>

        <record id="sales_product_list_view" model="ir.ui.view">
            <field name="name">sales.product.list</field>
            <field name="model">sales.product</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="price"/>
                    <field name="category"/>
                    <field name="customer_ids" widget="many2many_tags"/>
                    <field name="tag_ids" widget="many2many_tags"/>
                </list>
            </field>
        </record>

        <record id="sales_product_form_view" model="ir.ui.view">
            <field name="name">sales.product.form</field>
            <field name="model">sales.product</field>
            <field name="arch" type="xml">
                <form string="Product">
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="price"/>
                            <field name="category"/>
                            <field name="customer_ids" widget="many2many_tags"/>
                            <field name="tag_ids" widget="many2many_tags"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

        <record id="sales_product_action" model="ir.actions.act_window">
            <field name="name">Products</field>
            <field name="res_model">sales.product</field>
            <field name="view_mode">list,form</field>
        </record>

        <menuitem id="menu_sales_product"
                  name="Products"
                  parent="menu_sales_root"
                  action="sales_product_action"/>

    </data>
</odoo>