<odoo>
    <record id="order_line_list_view" model="ir.ui.view">
        <field name="name">order.line.list</field>
        <field name="model">order.line</field>
        <field name="arch" type="xml">
            <list>
                <field name="product_name"/>
                <field name="quantity"/>
                <field name="price"/>
                <field name="order_id"/>
                <field name="subtotal" readonly="1"/>
            </list>
        </field>
    </record>

    <record id="order_line_form_view" model="ir.ui.view">
        <field name="name">order.line.form</field>
        <field name="model">order.line</field>
        <field name="arch" type="xml">
            <form>
                <sheet>
                    <group>
                        <field name="product_name"/>
                        <field name="quantity"/>
                        <field name="price"/>
                        <field name="order_id"/>
                        <field name="subtotal" readonly="1"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_order_line" model="ir.actions.act_window">
        <field name="name">Order Lines</field>
        <field name="res_model">order.line</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_order_lines"
              name="Order Lines"
              parent="menu_sales_root"
              action="action_order_line"/>
</odoo>