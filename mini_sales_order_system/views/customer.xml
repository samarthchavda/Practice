<odoo>

    <!-- Customer List View -->
    <record id="view_sales_customer_list" model="ir.ui.view">
        <field name="name">sales.customer.list</field>
        <field name="model">sales.customer</field>
        <field name="arch" type="xml">
            <list string="Customers">

                <field name="name"/>
                <field name="email"/>
                <field name="phone"/>

                <field name="order_count"/>
                <field name="total_order_amount"/>
                <field name="total_paid_amount"/>
            </list>
        </field>
    </record>


    <!-- Customer Form View -->
    <record id="view_sales_customer_form" model="ir.ui.view">
        <field name="name">sales.customer.form</field>
        <field name="model">sales.customer</field>
        <field name="arch" type="xml">

            <form string="Customer">

                <header>

                    <button name="action_open_orders"
                            type="object"
                            class="oe_stat_button"
                            icon="fa-shopping-cart">

                        <field name="order_count"
                               string="Orders"
                               widget="statinfo"/>

                    </button>

                </header>

                <sheet>

                    <group>

                        <group>
                            <field name="name"/>
                            <field name="email"/>
                            <field name="phone"/>
                        </group>
                    </group>

                    <notebook>

                        <page string="Ledger">

                            <group>
                                <field name="order_count" readonly="1"/>
                                <field name="total_order_amount" readonly="1"/>
                                <field name="total_paid_amount" readonly="1"/>
                            </group>

                        </page>

                    </notebook>

                </sheet>

            </form>

        </field>
    </record>


    <!-- Customer Action -->
    <record id="action_sales_customer" model="ir.actions.act_window">
        <field name="name">Customers</field>
        <field name="res_model">sales.customer</field>
        <field name="view_mode">list,form</field>
    </record>


    <!-- Customer Menu -->
    <menuitem
        id="menu_sales_customer"
        name="Customers"
        parent="menu_order_root"
        action="action_sales_customer"
        sequence="2"/>

</odoo>