<odoo>
    <data>
        <record id="payment_list_view" model="ir.ui.view">
            <field name="name">sales.payment.list</field>
            <field name="model">sales.payment</field>
            <field name="arch" type="xml">
                <list>
                    <field name="payment_number"/>
                    <field name="order_id"/>
                    <field name="payment_date"/>
                    <field name="amount"/>
                    <field name="status"/>
                </list>
            </field>
        </record>

        <record id="payment_form_view" model="ir.ui.view">
            <field name="name">sales.payment.form</field>
            <field name="model">sales.payment</field>
            <field name="arch" type="xml">
                <form>

                    <header>
                        <button name="action_paid" string="Paid" type="object" class="btn-success"/>
                        <button name="action_cancel" string="Cancel" type="object" class="btn-danger"/>
                        <field name="status" widget="statusbar" statusbar_visible="draft,paid,cancel"/>
                    </header>
                    <group>
                        <field name="payment_number"/>
                        <field name="order_id"/>
                        <field name="payment_date"/>
                        <field name="amount"/>
                        <field name="status"/>
                    </group>
                </form>
            </field>
        </record>

         <record id="sales_payment_action" model="ir.actions.act_window">
            <field name="name">Payments</field>
            <field name="res_model">sales.payment</field>
            <field name="view_mode">list,form</field>
        </record>
            <menuitem id="menu_order_payment"
              name="payment"
              parent="menu_sales_root"
              action="sales_payment_action"/>

    </data>
</odoo>