<odoo>
    <record id="view_hospital_appointment_list" model="ir.ui.view">
        <field name="name">hospital.appointment.list</field>
        <field name="model">hospital.appointment</field>
        <field name="arch" type="xml">
            <list>
                <field name="appointment_number"/>
                <field name="patient_id"/>
                <field name="doctor_id"/>
                <field name="appointment_date"/>
                <field name="consultation_fee"/>
                <field name="state"/>
            </list>
        </field>
    </record>

    <record id="view_hospital_appointment_form" model="ir.ui.view">
        <field name="name">hospital.appointment.form</field>
        <field name="model">hospital.appointment</field>
        <field name="arch" type="xml">
            <form>
                <header>
                    <button name="action_confirm"
                            string="Confirm"
                            type="object"
                            class="btn-primary"
                            invisible="state != 'draft'"/>

                    <button name="action_done"
                            string="Done"
                            type="object"
                            class="btn-success"
                            invisible="state != 'confirmed'"/>

                    <button name="action_cancel"
                            string="Cancel"
                            type="object"
                            class="btn-danger"
                            invisible="state != 'draft'"/>

                    <field name="state" widget="statusbar" statusbar_visible="draft,confirmed,done,cancel"/>
                </header>

                <sheet>
                    <group>
                        <field name="appointment_number"/>
                        <field name="patient_id"/>
                        <field name="doctor_id"/>
                        <field name="appointment_date"/>
                        <field name="consultation_fee"/>
                    </group>

                    <group string="Reason">
                        <field name="reason"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_hospital_appointment" model="ir.actions.act_window">
        <field name="name">Appointments</field>
        <field name="res_model">hospital.appointment</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_hospital_appointment"
              name="Appointments"
              parent="menu_hospital_root"
              action="action_hospital_appointment"
              sequence="3"/>
</odoo>