<odoo>
    <record id="view_hospital_doctor_list" model="ir.ui.view">
        <field name="name">hospital.doctor.list</field>
        <field name="model">hospital.doctor</field>
        <field name="arch" type="xml">
            <list string="Doctors">
                <field name="name"/>
                <field name="specialization"/>
                <field name="phone"/>
                <field name="experience"/>
                <field name="consultation_fee"/>
                <field name="skill_ids" widget="many2many_tags"/>
            </list>
        </field>
    </record>

    <record id="view_hospital_doctor_form" model="ir.ui.view">
        <field name="name">hospital.doctor.form</field>
        <field name="model">hospital.doctor</field>
        <field name="arch" type="xml">
            <form string="Doctor">
                <div class="or_button_box" name="buttton_box">
                    <button name="action_open_appoinments"
                            type="object"
                            class="or_stat_button"
                            icon="fa-calender">
                        <field name="appointment_count"
                                widget="statinfo"
                                string="Appointments"/>
                    </button>
                </div>
                <sheet>
                    <group>
                        <field name="name"/>
                        <field name="specialization"/>
                        <field name="phone"/>
                        <field name="email"/>
                        <field name="experience"/>
                        <field name="consultation_fee"/>
                        <field name="active"/>
                        <field name="skill_ids" widget="many2many_tags"/>
                    </group>
                    <group>
                        <notebook>
                            <page string="Patients / Appointments">
                                <field name="appointment_ids">
                                    <list>
                                        <field name="patient_id"/>
                                        <field name="appointment_date"/>
                                        <field name="reason"/>
                                        <field name="consultation_fee"/>
                                        <field name="state"/>
                                    </list>
                                </field>
                            </page>
                        </notebook>
                    </group>
                 </sheet>
            </form>
        </field>
    </record>

    <record id="action_hospital_doctor" model="ir.actions.act_window">
        <field name="name">Doctors</field>
        <field name="res_model">hospital.doctor</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_hospital_root" name="Hospital"/>

    <menuitem id="menu_hospital_doctor"
              name="Doctors"
              parent="menu_hospital_root"
              action="action_hospital_doctor"/>
</odoo>