<odoo>
    <record id="library_list_view" model="ir.ui.view">
        <field name="name">libaray.management.new.list</field>
        <field name="model">lib.books.data</field>
        <field name="arch" type="xml">
            <list>
                <field name="book_number"/>
                <field name="b_name"/>
                <field name="b_description"/>
                <field name="b_price"/>
                <field name="quantity"/>
                <field name="author_id" required="1"/>
                <field name="barcode"/>
                <field name="active"/>
            </list>
        </field>
    </record>

    <record id="library_form_view" model="ir.ui.view">
        <field name="name">libaray.management.new.form</field>
        <field name="model">lib.books.data</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <field name="book_number"/>
                    <field name="b_name"/>
                    <field name="b_description"/>
                    <field name="b_price"/>
                    <field name="quantity"/>
                    <field name="author_id" required="1"/>
                    <field name="barcode" widget="barcode"/>
                    <field name="active"/>
                </group>
            </form>
        </field>
    </record>

    <record id="action_library" model="ir.actions.act_window">
        <field name="name">library management new</field>
        <field name="res_model">lib.books.data</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_library_root" name="lib_management"/>
    <menuitem id="menu_library"
              name="Books"
              action="action_library"
              parent="menu_library_root"
    />
</odoo>