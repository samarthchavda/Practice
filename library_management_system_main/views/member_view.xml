<odoo>
    <record id="library_member_list_view" model="ir.ui.view">
        <field name="name">libaray.management.new.list</field>
        <field name="model">lib.member</field>
        <field name="arch" type="xml">
            <list>
                <field name="member_number"/>
                <field name="name"/>
                <field name="age"/>
                <field name="contact_no"/>
                <field name="city"/>
            </list>
        </field>
    </record>

    <record id="library_member_form_view" model="ir.ui.view">
        <field name="name">libaray.management.new.form</field>
        <field name="model">lib.member</field>
        <field name="arch" type="xml">

            <form>
                <sheet>

                    <div class="oe_button_box" name="button_box">
                        <button name="action_open_purchase"
                                type="object"
                                class="oe_stat_button"
                                icon="fa fa-shopping-cart">

                            <field name="purchase_count"
                                   widget="statinfo"
                                   string="Purchases"/>
                        </button>
                    </div>

                    <group>
                        <field name="member_number"/>
                        <field name="name"/>
                        <field name="age"/>
                        <field name="contact_no"/>
                        <field name="city"/>
                    </group>

                </sheet>
            </form>

        </field>
    </record>

    <record id="action_member" model="ir.actions.act_window">
        <field name="name">Members</field>
        <field name="res_model">lib.member</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu-root"
              name="member"
              action="action_member"
              parent="menu_library_root"
              />

</odoo>