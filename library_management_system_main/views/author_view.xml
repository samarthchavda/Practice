<odoo>
     <record id="library_author_list_view" model="ir.ui.view">
        <field name="name">libaray.management.new.list</field>
        <field name="model">lib.author.data</field>
        <field name="arch" type="xml">
            <list>
                <field name="author_number"/>
                <field name="name"/>
            </list>
        </field>
    </record>
    <record id="library_author_form_view" model="ir.ui.view">
        <field name="name">libaray.management.new.list</field>
        <field name="model">lib.author.data</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <field name="author_number"/>
                    <field name="name"/>
                </group>
                <notebook>
                    <page string="books">
                        <field name="book_ids">
                            <list editable="top">
                                <field name="b_name"/>
                                <field name="b_description"/>
                                <field name="b_price"/>
                            </list>
                        </field>
                    </page>
                </notebook>
            </form>
        </field>
    </record>

    <record id="action_author" model="ir.actions.act_window">
        <field name="name">Author</field>
        <field name="res_model">lib.author.data</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_root"
              name="Author"
              parent="menu_library_root"
              action="action_author"
              />

</odoo>