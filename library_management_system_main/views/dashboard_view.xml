<odoo>

    <!-- Form View -->
    <record id="library_dashboard_form_view" model="ir.ui.view">
        <field name="name">library.dashboard.form</field>
        <field name="model">library.dashboard</field>

        <field name="arch" type="xml">
            <form string="Library Dashboard">

                <sheet>

                    <group col="2">

                        <group string="Books">
                            <field name="total_books" readonly="1"/>
                            <field name="low_stock_books" readonly="1"/>
                        </group>

                        <group string="Members Purchases">
                            <field name="total_members" readonly="1"/>
                            <field name="total_purchases" readonly="1"/>
                            <field name="total_amount" readonly="1"/>
                        </group>

                    </group>

                </sheet>

            </form>
        </field>
    </record>


    <!-- Action -->
    <record id="library_dashboard_action" model="ir.actions.act_window">
        <field name="name">Dashboard</field>
        <field name="res_model">library.dashboard</field>
        <field name="view_mode">form</field>
    </record>


    <!-- Menu -->
    <menuitem
        id="library_dashboard_menu"
        name="Dashboard"
        parent="menu_library_root"
        action="library_dashboard_action"
    />

</odoo>