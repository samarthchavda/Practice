<odoo>
    <data noupdate="1">

        <record id="seq_library_data" model="ir.sequence">
            <field name="name">library books id</field>
            <field name="code">lib.books.data</field>
            <field name="prefix">B</field>
            <field name="padding">3</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>

        <record id="seq_invoices_data" model="ir.sequence">
            <field name="name">library invoice id</field>
            <field name="code">books.purchase</field>
            <field name="prefix">INV</field>
            <field name="padding">3</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>

        <record id="seq_author_data" model="ir.sequence">
            <field name="name">library author id</field>
            <field name="code">lib.auth.data</field>
            <field name="prefix">A</field>
            <field name="padding">3</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>

        <record id="seq_member_data" model="ir.sequence">
            <field name="name">library member id</field>
            <field name="code">lib.member</field>
            <field name="prefix">M</field>
            <field name="padding">3</field>
            <field name="number_next">1</field>
            <field name="number_increment">1</field>
        </record>

        <record id="seq_library_book_barcode" model="ir.sequence">
            <field name="name">Library Book Barcode</field>
            <field name="code">library.book.barcode</field>
            <field name="prefix">BOOK-</field>
            <field name="padding">5</field>
        </record>

    </data>
</odoo>