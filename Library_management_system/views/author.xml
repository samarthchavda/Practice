<odoo>
    <record id="view_author_list" model="ir.ui.view">
        <field name="name">library.author.list</field>
        <field name="model">library.author</field>
        <field name="arch" type="xml">
            <list string="Authors">
                <field name="auth_name"/>
                <field name="book_count"/>
            </list>
        </field>
    </record>

    <record id="view_author_form" model="ir.ui.view">
        <field name="name">library.author.form</field>
        <field name="model">library.author</field>
        <field name="arch" type="xml">
            <form string="Author">
                <sheet>
                    <group>
                        <field name="auth_name"/>
                        <field name="book_count" readonly="1"/>
                    </group>

                    <group string="Books">
                        <field name="book_id">
                            <list editable="bottom">
                                <field name="b_name"/>
                                <field name="b_description"/>
                                <field name="b_price"/>
                            </list>
                        </field>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_author" model="ir.actions.act_window">
        <field name="name">Authors</field>
        <field name="res_model">library.author</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_author"
              name="Authors"
              parent="menu_library_root"
              action="action_author"/>
</odoo>