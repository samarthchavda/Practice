<odoo>

    <record id="issue_list_view" model="ir.ui.view">
        <field name="name">issue.book.list</field>
        <field name="model">issue.book</field>
        <field name="arch" type="xml">
            <list>
                <field name="customer_id"/>
                <field name="book_id"/>
                <field name="issue_date"/>
                <field name="return_date"/>
                <field name="status"/>
            </list>
        </field>
    </record>

    <record id="issue_form_view" model="ir.ui.view">
        <field name="name">issue.book.form</field>
        <field name="model">issue.book</field>
        <field name="arch" type="xml">
            <form string="Issue Book">
                <header>
                    <button name="action_return_book"
                            string="return book"
                            type="object"
                            class="btn-success"/>
                    <field name="status"
                           widget="statusbar"
                           statusbar_visible="issued,returned"/>
                </header>
                <sheet>
                    <group>
                        <field name="customer_id"/>
                        <field name="book_id"/>
                        <field name="issue_date"/>
                        <field name="return_date"/>
                        <field name="status"/>
                    </group>
                </sheet>
            </form>
        </field>
    </record>

    <record id="action_issue" model="ir.actions.act_window">
        <field name="name">Book Issues</field>
        <field name="res_model">issue.book</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu_issue"
              name="Book Issues"
              parent="menu_library_root"
              action="action_issue"/>

</odoo>