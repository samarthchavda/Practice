<odoo>
    <record id="book_data_list" model="ir.ui.view">
        <field name="name">library.book.list</field>
        <field name="model">library.data</field>
        <field name="arch" type="xml">
            <list>
                <field name="b_name"/>
                <field name="b_description"/>
                <field name="b_price"/>
            </list>
        </field>
    </record>

    <record id="book_data_form" model="ir.ui.view">
        <field name="name">library.book.form</field>
        <field name="model">library.data</field>
        <field name="arch" type="xml">
            <form>
                <group>
                    <field name="b_name"/>
                    <field name="author_id"/>
                    <field name="b_description"/>
                    <field name="b_price"/>
                </group>
            </form>
        </field>
    </record>

<!--    action-->
    <record id="actions_library" model="ir.actions.act_window">
        <field name="name">library</field>
        <field name="res_model">library.data</field>
        <field name="view_mode">list,form</field>
    </record>

     <menuitem id="menu_library_root" name="library Management"/>

    <menuitem id="menu_library"
                  name="books"
                  parent="menu_library_root"
                  action="actions_library"/>

</odoo>