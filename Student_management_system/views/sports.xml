<odoo>
    <record id="studenet_sports_data" model="ir.ui.view">
            <field name="name">student.sports.list</field>
            <field name="model">student.sports</field>
            <field name="arch" type="xml">
                <list editable="top">
                    <field name="name"/>
                </list>
            </field>
    </record>

    <record id="actions_sports" model="ir.actions.act_window">
            <field name="name">Students sports</field>
            <field name="res_model">student.sports</field>
            <field name="view_mode">list</field>
        </record>

    <menuitem id="menu_sports"
              name="sports data"
              parent="menu_student_root"
              action="actions_sports"/>
</odoo>