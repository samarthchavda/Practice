<odoo>
    <record id="final_result_list_view" model="ir.ui.view">
        <field name="name">student.final.result.list</field>
        <field name="model">student.result</field>
        <field name="arch" type="xml">
            <list string="Final Result">
                <field name="student_id"/>
                <field name="status"/>
            </list>
        </field>
    </record>

    <record id="action_final_result" model="ir.actions.act_window">
        <field name="name">Final Result</field>
        <field name="res_model">student.result</field>
        <field name="view_mode">list</field>
        <field name="view_id" ref="final_result_list_view"/>
    </record>

    <menuitem id="menu_final_result"
              name="Final Result"
              parent="menu_student_root"
              action="action_final_result"/>
</odoo>