<odoo>
        <record id="studenet_list_data" model="ir.ui.view">
            <field name="name">student.details.list</field>
            <field name="model">student.deatils</field>
            <field name="arch" type="xml">
                <list>
                    <field name="name"/>
                    <field name="roll_no"/>
                    <field name="phone"/>
                    <field name="student_active"/>
                    <field name="nationality"/>
                </list>
            </field>
        </record>

        <record id="studenet_form_data" model="ir.ui.view">
            <field name="name">student.details.form</field>
            <field name="model">student.deatils</field>
            <field name="arch" type="xml">
                <form string="Student Management">
                    <sheet>
                        <group>
                            <field name="name"/>
                            <field name="roll_no"/>
                            <field name="phone"/>
                            <field name="student_active"/>
                            <field name="nationality"/>

                            <field name="other"
                                   invisible="nationality == 'indian'"
                                   required="nationality == 'non_indian'"/>
                        </group>
                    </sheet>
                </form>
            </field>
        </record>

      <record id="student_list_search" model="ir.ui.view">
            <field name="name">student.details.search</field>
            <field name="model">student.deatils</field>
            <field name="arch" type="xml">
                <search string="Search Students">
                    <field name="name"/>
                    <field name="roll_no"/>
                    <field name="nationality"/>

                    <filter name="group_by_nationality"
                            string="Nationality"
                            context="{'group_by': 'nationality'}"/>
                </search>
            </field>
        </record>

        <record id="actions_student" model="ir.actions.act_window">
            <field name="name">Students</field>
            <field name="res_model">student.deatils</field>
            <field name="view_mode">list,form</field>
            <field name="search_view_id" ref="student_list_search"/>
        </record>

        <!-- MENU -->
        <menuitem id="menu_student_root" name="Student Management"/>

        <menuitem id="menu_student"
                  name="Students"
                  parent="menu_student_root"
                  action="actions_student"/>

</odoo>