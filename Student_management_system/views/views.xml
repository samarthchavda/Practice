<odoo>
    <record id="studenet_list_data" model="ir.ui.view">
        <field name="name">student management</field>
        <field name="model">student.deatils</field>
        <field name="arch" type="xml">
            <list string="student_data">
                <field name="name"/>
                <field name="age"/>
                <field name="phone"/>
            </list>
        </field>
    </record>

    <record id="studenet_form_data" model="ir.ui.view">
        <field name="name">student management</field>
        <field name="model">student.deatils</field>
        <field name="arch" type="xml">
            <form string="student_data">
                <group>
                    <field name="name"/>
                    <field name="age"/>
                    <field name="phone"/>
                </group>
            </form>
        </field>
    </record>

    <record id="actions_student" model="ir.actions.act_window">
        <field name="name">student</field>
        <field name="res_model">student.deatils</field>
        <field name="view_mode">list,form</field>
    </record>

    <menuitem id="menu-student-management" name="student-management"/>
    <menuitem id="menu-student-management-new" name="students" action="actions_student" parent="menu-student-management"/>

</odoo>